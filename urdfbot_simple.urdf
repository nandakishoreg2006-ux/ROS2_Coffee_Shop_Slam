<?xml version="1.0"?>
<robot name="urdfbot_simple">

  <!-- ==============================================================
       MATERIALS
  ============================================================== -->
  <material name="orange">
    <color rgba="0.8 0.35 0.05 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.2 0.8 1.0"/>
  </material>

  <!-- ==============================================================
       BASE FOOTPRINT  — ground-level navigation reference
       Required by SLAM Toolbox and Nav2 as robot_base_frame
  ============================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!--
      main wheel radius = 0.12 m
      chassis half-height = 0.08 m
      → base_link origin sits 0.12 m above ground
    -->
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- ==============================================================
       BASE LINK  — rover chassis  (0.65 × 0.45 × 0.16 m)
  ============================================================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.65 0.45 0.16"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.65 0.45 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="14.0"/>
      <!-- box: ixx=(1/12)*m*(y²+z²), iyy=(1/12)*m*(x²+z²), izz=(1/12)*m*(x²+y²) -->
      <inertia
        ixx="0.3639"
        iyy="0.5768"
        izz="0.8306"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ==============================================================
       LEFT DRIVE WHEEL  (continuous, mid-left)
  ============================================================== -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.07"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <!-- cylinder spinning about Y:
           ixx=izz=(1/12)*m*(3r²+h²) = (1/12)*1.5*(0.0432+0.0049) = 0.00601
           iyy=(1/2)*m*r²            = 0.5*1.5*0.0144             = 0.01080 -->
      <inertia
        ixx="0.00601"
        iyy="0.01080"
        izz="0.00601"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y = chassis_y/2 + wheel_thickness/2 + 0.01 gap = 0.225+0.035+0.01 = 0.27 -->
    <!-- z = 0 (wheel centre aligns with base_link centre vertically) -->
    <origin xyz="0.0 0.27 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.1"/>
  </joint>

  <!-- ==============================================================
       RIGHT DRIVE WHEEL  (continuous, mid-right)
  ============================================================== -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.07"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia
        ixx="0.00601"
        iyy="0.01080"
        izz="0.00601"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.27 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.1"/>
  </joint>

  <!-- ==============================================================
       FRONT CASTER  — balance wheel (sphere, frictionless)
  ============================================================== -->
  <link name="front_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <!-- solid sphere: I = (2/5)*m*r² = 0.4*0.5*0.0036 = 0.00072 -->
      <inertia
        ixx="0.00072"
        iyy="0.00072"
        izz="0.00072"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!--
    caster centre z relative to base_link:
    must touch ground → caster_r = 0.06
    base_link is already lifted by wheel_r (0.12)
    so caster bottom must be at -0.12 relative to base_link
    caster centre z = -0.12 + 0.06 = -0.06
  -->
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.25 0.0 -0.06" rpy="0 0 0"/>
  </joint>

  <!-- ==============================================================
       REAR-LEFT CASTER  — balance wheel
  ============================================================== -->
  <link name="rear_left_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia
        ixx="0.00072"
        iyy="0.00072"
        izz="0.00072"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rear_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_caster"/>
    <origin xyz="-0.25 0.15 -0.06" rpy="0 0 0"/>
  </joint>

  <!-- ==============================================================
       REAR-RIGHT CASTER  — balance wheel
  ============================================================== -->
  <link name="rear_right_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia
        ixx="0.00072"
        iyy="0.00072"
        izz="0.00072"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rear_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_caster"/>
    <origin xyz="-0.25 -0.15 -0.06" rpy="0 0 0"/>
  </joint>

  <!-- ==============================================================
       SENSOR MAST  — vertical pole on chassis top
  ============================================================== -->
  <link name="sensor_mast">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.20"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.20"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia
        ixx="0.00087"
        iyy="0.00087"
        izz="0.000005"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- mast base at top of chassis: z = chassis_z/2 = 0.08 -->
  <joint name="sensor_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mast"/>
    <origin xyz="0.05 0.0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ==============================================================
       LIDAR LINK  — 360° 2D scan, top of mast
       Topic  : /scan  (sensor_msgs/LaserScan)
       SLAM Toolbox reads this topic directly
  ============================================================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia
        ixx="0.00005"
        iyy="0.00005"
        izz="0.00005"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- mast visual origin offset = 0.10, mast length = 0.20 → top at 0.20 from joint -->
  <joint name="lidar_joint" type="fixed">
    <parent link="sensor_mast"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

  <!-- ==============================================================
       CAMERA LINK  — front-facing RGB
       Topics: /camera/image_raw   (sensor_msgs/Image)
               /camera/camera_info (sensor_msgs/CameraInfo)
  ============================================================== -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.10 0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.10 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <inertia
        ixx="0.00005"
        iyy="0.00005"
        izz="0.00005"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- x = chassis_x/2 + camera_depth/2 = 0.325 + 0.025 = 0.35 -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.35 0.0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ROS optical frame: Z forward, X right, Y down -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ==============================================================
       GAZEBO: WHEEL FRICTION
  ============================================================== -->

  <gazebo reference="left_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- Casters: near-zero friction so they glide without resisting turns -->
  <gazebo reference="front_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_left_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_right_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="sensor_mast">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ==============================================================
       DIFFERENTIAL DRIVE PLUGIN
       Subscribes : /cmd_vel  (geometry_msgs/Twist)
       Publishes  : /odom     (nav_msgs/Odometry)
       TF         : odom → base_footprint
       Teleop     : ros2 run teleop_twist_keyboard teleop_twist_keyboard
  ============================================================== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- separation = 2 × y_offset = 2 × 0.27 = 0.54 m -->
      <wheel_separation>0.54</wheel_separation>
      <!-- diameter = 2 × radius = 0.24 m -->
      <wheel_diameter>0.24</wheel_diameter>

      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>

      <!-- Topics (no namespace so teleop works out of the box) -->
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>

      <!-- SLAM-compatible frame names -->
      <robot_base_frame>base_footprint</robot_base_frame>
      <odometry_frame>odom</odometry_frame>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <update_rate>50.0</update_rate>

    </plugin>
  </gazebo>

  <!-- ==============================================================
       LIDAR PLUGIN  — sensor_msgs/LaserScan → /scan
       SLAM Toolbox (online_async) reads /scan directly.
       base_frame = base_footprint, odom_frame = odom (set in slam_params)
  ============================================================== -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10.0</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.015</stddev>
        </noise>
      </ray>

      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>

    </sensor>
  </gazebo>

  <!-- ==============================================================
       CAMERA PLUGIN  — publishes image_raw + camera_info
  ============================================================== -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="front_camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30.0</update_rate>

      <camera name="front_camera">
        <horizontal_fov>1.3963</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>100.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </camera>

      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=camera/image_raw</remapping>
          <remapping>~/camera_info:=camera/camera_info</remapping>
        </ros>
        <camera_name>front_camera</camera_name>
        <frame_name>camera_optical_frame</frame_name>
        <hack_baseline>0.0</hack_baseline>
      </plugin>

    </sensor>
  </gazebo>

</robot>
